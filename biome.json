{
    "$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
    "assist": {
        "enabled": false,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "useImportType": "off",
                "noNonNullAssertion": "off"
            },
            "suspicious": {
                "noExplicitAny": "warn"
            },
            "correctness": {
                "noUnusedFunctionParameters": "error"
            }
        }
    },
    "formatter": {
        "enabled": true,
        "formatWithErrors": false,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "trailingCommas": "all",
            "semicolons": "asNeeded"
        },
        "parser": {
            "unsafeParameterDecoratorsEnabled": true
        }
    },
    "overrides": [
        {
            "includes": [
                "**/*.spec.ts",
                "**/*.test.ts",
                "**/test/**"
            ],
            "javascript": {
                "parser": {
                    "unsafeParameterDecoratorsEnabled": true
                }
            },
            "linter": {
                "rules": {
                    "suspicious": {
                        "noExplicitAny": "off"
                    }
                }
            }
        }
    ],
    "files": {
        "includes": [
            "src/**/*.ts"
        ]
    }
}
