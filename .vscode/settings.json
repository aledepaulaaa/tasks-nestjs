{
  "biome.binary": "E:\\curso_nestjs\\tasks-nestjs\\node_modules\\.bin\\biome.exe",
  // 2. Ativa a extensão e permite que ela busque no path se necessário
  "biome.enabled": true,
  "biome.requireConfiguration": true,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "always",
    "source.fixAll.biome": "always",
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  }
}
